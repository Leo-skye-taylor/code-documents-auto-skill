{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Documentation Schema",
  "description": "Schema for AI-oriented code documentation",
  "version": "1.0",
  "definitions": {
    "frontmatter": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Document title"
        },
        "type": {
          "type": "string",
          "enum": ["module", "feature", "api", "guide", "changelog", "decision"],
          "description": "Document type"
        },
        "version": {
          "type": "string",
          "description": "Document version"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated"],
          "description": "Document status"
        },
        "created": {
          "type": "string",
          "format": "date",
          "description": "Creation date"
        },
        "updated": {
          "type": "string",
          "format": "date",
          "description": "Last update date"
        },
        "author": {
          "type": "string",
          "description": "Document author"
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Related modules"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Document tags"
        }
      },
      "required": ["title", "type"]
    },
    "moduleDoc": {
      "type": "object",
      "properties": {
        "module": {
          "type": "string",
          "description": "Module name"
        },
        "version": {
          "type": "string",
          "description": "Module version"
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "experimental"],
          "description": "Module status"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Module dependencies"
        }
      },
      "required": ["module"]
    },
    "featureDoc": {
      "type": "object",
      "properties": {
        "feature": {
          "type": "string",
          "description": "Feature name"
        },
        "version": {
          "type": "string",
          "description": "Feature version"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in-progress", "completed", "deprecated"],
          "description": "Feature status"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Feature priority"
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Related modules"
        }
      },
      "required": ["feature"]
    },
    "changeRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Change date"
        },
        "type": {
          "type": "string",
          "enum": ["feature", "bugfix", "refactor", "docs", "test", "config", "deps", "perf", "security", "style"],
          "description": "Change type"
        },
        "title": {
          "type": "string",
          "description": "Change title"
        },
        "author": {
          "type": "string",
          "description": "Change author"
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Affected modules"
        },
        "impact": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Impact level"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "in-progress", "reverted"],
          "description": "Change status"
        },
        "tickets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Related tickets"
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Change reviewers"
        },
        "breaking": {
          "type": "boolean",
          "description": "Whether this is a breaking change"
        },
        "version": {
          "type": "string",
          "description": "Version introduced"
        }
      },
      "required": ["date", "type", "title", "author", "modules", "impact"]
    },
    "decisionRecord": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Decision date"
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "accepted", "deprecated", "superseded"],
          "description": "Decision status"
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Related modules"
        }
      },
      "required": ["date", "status"]
    }
  },
  "properties": {
    "documents": {
      "type": "array",
      "items": {
        "oneOf": [
          {"$ref": "#/definitions/moduleDoc"},
          {"$ref": "#/definitions/featureDoc"},
          {"$ref": "#/definitions/changeRecord"},
          {"$ref": "#/definitions/decisionRecord"}
        ]
      }
    }
  }
}
